# Copy to .env for local testing. Never commit the real .env.
# GitHub Actions reads these from repository Secrets instead.

# Travelpayouts (Aviasales) Data API
# Get from https://www.travelpayouts.com/ → Dashboard → API / Developers
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token_here
# Marker is optional; only used for affiliate attribution
TRAVELPAYOUTS_MARKER=

# Telegram bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
TELEGRAM_CHAT_ID=123456789
